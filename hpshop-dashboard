let currentAgent = null;
let waActive = true;

// ═══════════════════════════════════════
// LOGIN
// ═══════════════════════════════════════
function doLogin(){
  const u=document.getElementById("loginUser").value.trim();
  const p=document.getElementById("loginPass").value.trim();
  const agent = AGENTS.find(a=>a.id===u && a.pass===p);
  if(agent){
    currentAgent = agent;
    document.getElementById("loginScreen").style.display="none";
    document.getElementById("appLayout").style.display="grid";
    document.getElementById("sbName").textContent=agent.name;
    document.getElementById("sbAvatar").textContent=agent.name.split(" ").map(n=>n[0]).join("").slice(0,2);
    initDashboard();
  } else {
    document.getElementById("loginError").style.display="block";
  }
}

function logout(){
  document.getElementById("loginScreen").style.display="flex";
  document.getElementById("appLayout").style.display="none";
}

// LOGIN avec Enter
document.addEventListener("keydown",e=>{if(e.key==="Enter" && document.getElementById("loginScreen").style.display!=="none") doLogin();});

// ═══════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════
function showPage(name, btn){
  document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
  document.querySelectorAll(".sb-link").forEach(l=>l.classList.remove("active"));
  document.getElementById("page-"+name).classList.add("active");
  if(btn) btn.classList.add("active");
  const titles={dashboard:"Tableau de bord",commandes:"Commandes",stock:"Gestion Stock",agents:"Équipe Agents",whatsapp:"Configuration WhatsApp",rapido:"Livraisons Rapido"};
  document.getElementById("topbarTitle").textContent=titles[name]||name;
  if(name==="commandes") renderAllOrders(orders);
  if(name==="stock") renderStock();
  if(name==="agents") renderAgents();
  if(name==="rapido") renderRapido();
}

// ═══════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════
function initDashboard(){
  const total = orders.length;
  const attente = orders.filter(o=>o.statut==="Nouvelle"||o.statut==="Confirmée").length;
  const livrees = orders.filter(o=>o.statut==="Livrée").length;
  const ca = orders.filter(o=>o.statut!=="Annulée").reduce((s,o)=>s+parseInt(o.prix.replace(/[^\d]/g,"")),0);

  document.getElementById("totalCommandes").textContent = total;
  document.getElementById("enAttente").textContent = attente;
  document.getElementById("livrees").textContent = livrees;
  document.getElementById("chiffre").textContent = (ca/1000000).toFixed(1)+"M";
  document.getElementById("newOrderBadge").textContent = orders.filter(o=>o.statut==="Nouvelle").length;

  // Chart
  const days=["Lun","Mar","Mer","Jeu","Ven","Sam","Dim"];
  const vals=[5,8,6,12,9,15,11];
  const max=Math.max(...vals);
  document.getElementById("chartBars").innerHTML=vals.map((v,i)=>`
    <div class="bar-wrap">
      <div class="bar-val">${v}</div>
      <div class="bar" style="height:${(v/max)*90}px"></div>
      <div class="bar-lbl">${days[i]}</div>
    </div>`).join("");

  // Top produits
  const counts={};
  orders.forEach(o=>{counts[o.produit]=(counts[o.produit]||0)+1;});
  const top=Object.entries(counts).sort((a,b)=>b[1]-a[1]).slice(0,5);
  document.getElementById("topProduits").innerHTML=top.map(([nom,cnt],i)=>`
    <div style="display:flex;align-items:center;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);">
      <span style="font-size:.8rem;font-weight:700;">${["🥇","🥈","🥉","4️⃣","5️⃣"][i]} ${nom}</span>
      <span class="badge badge-confirm">${cnt} cmd</span>
    </div>`).join("");

  // Recent orders (5 dernières)
  document.getElementById("recentOrders").innerHTML=orders.slice(0,5).map(o=>renderRow(o,true)).join("");
}

// ═══════════════════════════════════════
// ORDERS TABLE
// ═══════════════════════════════════════
function renderRow(o, simple=false){
  const badgeClass={Nouvelle:"badge-new",Confirmée:"badge-confirm","En livraison":"badge-livraison",Livrée:"badge-livre",Annulée:"badge-annule"}[o.statut]||"badge-new";
  const icons={Nouvelle:"🆕",Confirmée:"✅","En livraison":"🚚",Livrée:"📬",Annulée:"❌"};
  if(simple) return `<tr>
    <td style="font-weight:800;color:var(--red)">${o.id}</td>
    <td>${o.client}</td>
    <td>${o.emoji} ${o.produit}</td>
    <td>${o.ville}</td>
    <td style="font-weight:800">${o.prix}</td>
    <td><span class="badge ${badgeClass}">${icons[o.statut]} ${o.statut}</span></td>
    <td><div class="action-btns">
      <button class="btn-sm btn-red" onclick="openOrder('${o.id}')">Voir</button>
      <button class="btn-sm btn-green" onclick="sendWA('${o.id}')">💬</button>
    </div></td>
  </tr>`;
  return `<tr>
    <td style="font-weight:800;color:var(--red)">${o.id}</td>
    <td style="font-size:.75rem">${o.date}</td>
    <td style="font-weight:700">${o.client}</td>
    <td>${o.tel}</td>
    <td>${o.emoji} ${o.produit}</td>
    <td>${o.ville}</td>
    <td style="font-weight:800">${o.prix}</td>
    <td style="font-size:.75rem">${o.paiement}</td>
    <td><span class="badge ${badgeClass}">${icons[o.statut]} ${o.statut}</span></td>
    <td style="font-size:.75rem">${o.agent}</td>
    <td><div class="action-btns">
      <button class="btn-sm btn-red" onclick="openOrder('${o.id}')">👁</button>
      <button class="btn-sm btn-green" onclick="sendWA('${o.id}')">💬</button>
      <button class="btn-sm btn-outline" onclick="changeStatus('${o.id}')">✏️</button>
    </div></td>
  </tr>`;
}

function renderAllOrders(list){
  document.getElementById("allOrders").innerHTML=list.map(o=>renderRow(o)).join("");
}

function filterOrders(q){
  const filtered=orders.filter(o=>o.client.toLowerCase().includes(q.toLowerCase())||o.id.includes(q)||o.produit.toLowerCase().includes(q.toLowerCase()));
  renderAllOrders(filtered);
}

function filterByStatus(s){
  renderAllOrders(s==="all"?orders:orders.filter(o=>o.statut===s));
}

function filterByCity(c){
  renderAllOrders(c==="all"?orders:orders.filter(o=>o.ville===c));
}

// ═══════════════════════════════════════
// ORDER MODAL
// ═══════════════════════════════════════
function openOrder(id){
  const o=orders.find(x=>x.id===id);
  if(!o)return;
  document.getElementById("modalId").textContent="#"+o.id;
  document.getElementById("modalContent").innerHTML=`
    <div class="modal-field"><label>Client</label><span>${o.client}</span></div>
    <div class="modal-field"><label>Téléphone</label><span>${o.tel}</span></div>
    <div class="modal-field"><label>Produit</label><span>${o.emoji} ${o.produit}</span></div>
    <div class="modal-field"><label>Montant</label><span style="color:var(--red);font-weight:800">${o.prix}</span></div>
    <div class="modal-field"><label>Ville</label><span>${o.ville}</span></div>
    <div class="modal-field"><label>Adresse</label><span>${o.adresse}</span></div>
    <div class="modal-field"><label>Paiement</label><span>${o.paiement}</span></div>
    <div class="modal-field"><label>Statut</label><span>${o.statut}</span></div>
    <div class="modal-field"><label>Agent</label><span>${o.agent}</span></div>
    <div class="modal-field"><label>Date</label><span>${o.date}</span></div>`;
  document.getElementById("modalActions").innerHTML=`
    <button class="btn-sm btn-green" onclick="updateStatus('${o.id}','Confirmée');closeModal()">✅ Confirmer</button>
    <button class="btn-sm btn-red" style="background:#3B82F6" onclick="updateStatus('${o.id}','En livraison');closeModal()">🚚 En livraison</button>
    <button class="btn-sm btn-green" onclick="updateStatus('${o.id}','Livrée');closeModal()">📬 Livrée</button>
    <button class="btn-sm" style="background:#E74C3C;color:#fff" onclick="updateStatus('${o.id}','Annulée');closeModal()">❌ Annuler</button>
    <button class="btn-sm btn-green" onclick="sendWA('${o.id}');closeModal()">💬 WhatsApp</button>
    <button class="btn-sm btn-outline" onclick="closeModal()">Fermer</button>`;
  document.getElementById("orderModal").classList.add("show");
}

function closeModal(){document.getElementById("orderModal").classList.remove("show");}
document.getElementById("orderModal").addEventListener("click",function(e){if(e.target===this)closeModal();});

function updateStatus(id,statut){
  const o=orders.find(x=>x.id===id);
  if(o){o.statut=statut;showToast("✅ Commande "+id+" → "+statut);}
}

function changeStatus(id){openOrder(id);}

// ═══════════════════════════════════════
// WHATSAPP
// ═══════════════════════════════════════
function sendWA(id){
  const o=orders.find(x=>x.id===id);
  if(!o)return;
  const waNum=document.getElementById("waNumber").value.replace(/[^0-9]/g,"");
  const msg=`🛍 *Nouvelle commande HPSHOP !*

👤 Client : ${o.client}
📞 Tel : ${o.tel}
📦 Produit : ${o.emoji} ${o.produit}
💰 Montant : ${o.prix}
📍 Adresse : ${o.adresse}
🏙️ Ville : ${o.ville}
💳 Paiement : ${o.paiement}
🕐 Heure : ${o.date}

⚡ Livraison via *Rapido* — À confirmer rapidement !`;
  window.open(`https://wa.me/${waNum||"224XXXXXXXX"}?text=${encodeURIComponent(msg)}`,"_blank");
  showToast("💬 Message WhatsApp envoyé !");
}

function testWA(){
  const waNum=document.getElementById("waNumber").value.replace(/[^0-9]/g,"");
  const msg="🛍 *Test HPSHOP* — Notification de commande bien configurée ✅

Votre système de commande est opérationnel !";
  window.open(`https://wa.me/${waNum||"224XXXXXXXX"}?text=${encodeURIComponent(msg)}`,"_blank");
}

function saveWA(){showToast("✅ Numéro WhatsApp sauvegardé !");}

function toggleWA(){
  waActive=!waActive;
  const t=document.getElementById("waToggle");
  t.classList.toggle("on",waActive);
  showToast(waActive?"✅ Notifications WhatsApp activées":"⚠️ Notifications désactivées");
}

function exportWA(){
  const nouvelles=orders.filter(o=>o.statut==="Nouvelle");
  const waNum=document.getElementById("waNumber").value.replace(/[^0-9]/g,"");
  const msg=`📊 *Rapport commandes HPSHOP*

📦 Total : ${orders.length} commandes
🆕 Nouvelles : ${nouvelles.length}
✅ Livrées : ${orders.filter(o=>o.statut==="Livrée").length}

${nouvelles.slice(0,5).map(o=>`• ${o.id} — ${o.client} — ${o.produit} — ${o.prix}`).join("
")}`;
  window.open(`https://wa.me/${waNum||"224XXXXXXXX"}?text=${encodeURIComponent(msg)}`,"_blank");
}

function exportCSV(){
  const header="ID,Date,Client,Tel,Produit,Ville,Prix,Paiement,Statut,Agent
";
  const rows=orders.map(o=>`${o.id},${o.date},${o.client},${o.tel},${o.produit},${o.ville},${o.prix},${o.paiement},${o.statut},${o.agent}`).join("
");
  const blob=new Blob([header+rows],{type:"text/csv"});
  const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="hpshop-commandes.csv";a.click();
  showToast("📥 Export CSV téléchargé !");
}

