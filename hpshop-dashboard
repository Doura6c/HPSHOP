  const m = String(Math.floor(Math.random()*60)).padStart(2,"0");
  orders.push({
    id: "HP"+String(i).padStart(4,"0"),
    date: `26/04/2026 ${h}:${m}`,
    client: ["Fatoumata K.","Mamadou B.","Aïssatou M.","Seydou D.","Kadiatou S.","Ibrahim C.","Mariama T.","Oumar L."][Math.floor(Math.random()*8)],
