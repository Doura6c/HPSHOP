function renderRapido(){
  const toDispatch=orders.filter(o=>o.statut==="Confirmée").slice(0,8);
  const statuts=["En attente Rapido","Pris en charge","En route","Livré"];
  document.getElementById("rapidoTable").innerHTML=toDispatch.map(o=>{
    const rs=statuts[Math.floor(Math.random()*statuts.length)];
    const bc=rs==="Livré"?"badge-livre":rs==="En route"?"badge-livraison":"badge-confirm";
    return `<tr>
      <td style="font-weight:800;color:var(--red)">${o.id}</td>
      <td>${o.client}</td>
      <td>${o.emoji} ${o.produit}</td>
      <td>${o.ville}</td>
      <td style="font-size:.8rem">${o.adresse}</td>
      <td><span class="badge ${bc}">${rs}</span></td>
      <td><button class="btn-sm btn-red" onclick="showToast('🚚 Dispatch Rapido envoyé pour ${o.id}')">Dispatcher</button></td>
    </tr>`;
  }).join("");
}

// ═══════════════════════════════════════
// TOAST
// ═══════════════════════════════════════
let toastTimer;
function showToast(msg){
  const t=document.getElementById("toast");
  t.textContent=msg; t.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove("show"),3500);
}

