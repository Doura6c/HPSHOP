];

function renderStock(filter="all"){
  const list = filter==="low"?stockData.filter(s=>s.qty>0&&s.qty<=5):filter==="out"?stockData.filter(s=>s.qty===0):stockData;
  document.getElementById("stockGrid").innerHTML=list.map((s,i)=>{
    const badgeClass=s.qty===0?"badge-stock-no":s.qty<=5?"badge-stock-low":"badge-stock-ok";
    const badgeTxt=s.qty===0?"❌ Rupture":s.qty<=5?"⚠️ Stock faible":"✅ En stock";
    return `<div class="stock-item">
      <div class="stock-emoji">${s.emoji}</div>
      <div class="stock-name">${s.nom}</div>
      <span class="badge ${badgeClass}" style="margin-bottom:.5rem">${badgeTxt}</span>
      <div class="stock-actions">
        <button class="qty-btn" onclick="updateQty(${i},-1)">−</button>
        <div class="qty-display" id="qty-${i}" style="color:${s.qty===0?'var(--red)':s.qty<=5?'#D97706':'var(--green)'}">${s.qty}</div>
        <button class="qty-btn" onclick="updateQty(${i},1)">+</button>
        <button class="btn-sm btn-red" style="margin-left:.3rem;font-size:.65rem" onclick="showToast('📲 Alerte stock envoyée sur WhatsApp !')">📲</button>
      </div>
    </div>`;
  }).join("");
}

function updateQty(i,delta){
  stockData[i].qty=Math.max(0,stockData[i].qty+delta);
  renderStock();
  if(stockData[i].qty===0) showToast("⚠️ "+stockData[i].nom+" : RUPTURE DE STOCK !");
  else if(stockData[i].qty<=3) showToast("⚠️ "+stockData[i].nom+" : Stock faible ("+stockData[i].qty+" restants)");
}

function filterStock(f){renderStock(f);}

